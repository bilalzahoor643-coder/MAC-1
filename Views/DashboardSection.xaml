<UserControl x:Class="MAC_1.Views.DashboardSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="32,24,32,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="Auto"/>
                <!-- Stat Cards -->
                <RowDefinition Height="Auto"/>
                <!-- Spacer -->
                <RowDefinition Height="Auto"/>
                <!-- Active Downloads -->
                <RowDefinition Height="Auto"/>
                <!-- Spacer -->
                <RowDefinition Height="Auto"/>
                <!-- Recent Completed -->
            </Grid.RowDefinitions>

            <!-- ===================== 1. HEADER ===================== -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="Dashboard" FontSize="26" FontWeight="Bold" Foreground="#1A1A2E"/>
                <TextBlock Text="Overview of your download activity" FontSize="14" Foreground="#6B7280" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- ===================== 2. STAT CARDS ROW ===================== -->
            <UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,32">

                <!-- Total Downloads -->
                <Border Style="{StaticResource StatCardStyle}" Margin="0,0,12,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Total Downloads" FontSize="13" Foreground="#6B7280" FontWeight="Medium"/>
                            <TextBlock Text="128" FontSize="32" FontWeight="Bold" Foreground="#1A1A2E" Margin="0,6,0,0"/>
                            <TextBlock Text="All time downloads" FontSize="11" Foreground="#9CA3AF" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="44" Height="44" CornerRadius="10" Background="#EFF6FF" VerticalAlignment="Top">
                            <fa:ImageAwesome Icon="CloudDownload" Width="20" Foreground="#0077FF" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Downloading -->
                <Border Style="{StaticResource StatCardStyle}" Margin="6,0,6,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Downloading" FontSize="13" Foreground="#6B7280" FontWeight="Medium"/>
                            <TextBlock Text="2" FontSize="32" FontWeight="Bold" Foreground="#1A1A2E" Margin="0,6,0,0"/>
                            <TextBlock Text="Active downloads" FontSize="11" Foreground="#9CA3AF" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="44" Height="44" CornerRadius="10" Background="#EFF6FF" VerticalAlignment="Top">
                            <fa:ImageAwesome Icon="Download" Width="20" Foreground="#0077FF" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Completed -->
                <Border Style="{StaticResource StatCardStyle}" Margin="6,0,6,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Completed" FontSize="13" Foreground="#6B7280" FontWeight="Medium"/>
                            <TextBlock Text="126" FontSize="32" FontWeight="Bold" Foreground="#1A1A2E" Margin="0,6,0,0"/>
                            <TextBlock Text="Finished downloads" FontSize="11" Foreground="#9CA3AF" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="44" Height="44" CornerRadius="10" Background="#F0FDF4" VerticalAlignment="Top">
                            <fa:ImageAwesome Icon="CheckCircle" Width="20" Foreground="#22C55E" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Paused -->
                <Border Style="{StaticResource StatCardStyle}" Margin="6,0,6,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Paused" FontSize="13" Foreground="#6B7280" FontWeight="Medium"/>
                            <TextBlock Text="3" FontSize="32" FontWeight="Bold" Foreground="#1A1A2E" Margin="0,6,0,0"/>
                            <TextBlock Text="Paused downloads" FontSize="11" Foreground="#9CA3AF" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="44" Height="44" CornerRadius="10" Background="#FFFBEB" VerticalAlignment="Top">
                            <fa:ImageAwesome Icon="PauseCircle" Width="20" Foreground="#F97316" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Failed -->
                <Border Style="{StaticResource StatCardStyle}" Margin="12,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Failed" FontSize="13" Foreground="#6B7280" FontWeight="Medium"/>
                            <TextBlock Text="1" FontSize="32" FontWeight="Bold" Foreground="#1A1A2E" Margin="0,6,0,0"/>
                            <TextBlock Text="Failed downloads" FontSize="11" Foreground="#9CA3AF" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="44" Height="44" CornerRadius="10" Background="#FEF2F2" VerticalAlignment="Top">
                            <fa:ImageAwesome Icon="TimesCircle" Width="20" Foreground="#EF4444" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

            </UniformGrid>

            <!-- ===================== 3. ACTIVE DOWNLOADS TABLE ===================== -->
            <Border Grid.Row="3" Background="{StaticResource DashCardBg}" BorderBrush="{StaticResource DashBorder}"
                    BorderThickness="1" CornerRadius="12" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Header -->
                        <RowDefinition Height="Auto"/>
                        <!-- Column Headers -->
                        <RowDefinition Height="Auto"/>
                        <!-- Rows -->
                    </Grid.RowDefinitions>

                    <!-- Section Header -->
                    <Grid Grid.Row="0" Margin="20,16,20,0">
                        <TextBlock Text="Active Downloads" Style="{StaticResource DashSectionTitle}"/>
                        <TextBlock Text="View All" Style="{StaticResource DashViewAllBtn}" HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Column Headers -->
                    <Grid Grid.Row="1" Margin="20,12,20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <!-- FILE NAME -->
                            <ColumnDefinition Width="1.2*"/>
                            <!-- SIZE -->
                            <ColumnDefinition Width="1.8*"/>
                            <!-- PROGRESS -->
                            <ColumnDefinition Width="1.2*"/>
                            <!-- SPEED -->
                            <ColumnDefinition Width="1*"/>
                            <!-- TIME LEFT -->
                            <ColumnDefinition Width="1.2*"/>
                            <!-- STATUS -->
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="FILE NAME" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF"/>
                        <TextBlock Grid.Column="1" Text="SIZE" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF"/>
                        <TextBlock Grid.Column="2" Text="PROGRESS" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF"/>
                        <TextBlock Grid.Column="3" Text="SPEED" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF"/>
                        <TextBlock Grid.Column="4" Text="TIME LEFT" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF"/>
                        <TextBlock Grid.Column="5" Text="STATUS" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF"/>
                    </Grid>

                    <Border Grid.Row="1" Height="1" Background="{StaticResource DashBorder}" Margin="20,8,20,0"/>

                    <!-- Sample Rows -->
                    <StackPanel Grid.Row="2">
                        <!-- Row 1 -->
                        <Border Padding="16,12,16,12" BorderBrush="{StaticResource DashBorder}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="1.8*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="32" Height="32" CornerRadius="6" Background="#EFF6FF" Margin="0,0,10,0">
                                        <fa:ImageAwesome Icon="FileVideoOutline" Width="14" Foreground="#0077FF" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="ubuntu-24.04-desktop-amd64.iso" Foreground="#1A1A2E" FontSize="13" FontWeight="Medium"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="280"/>
                                </StackPanel>

                                <TextBlock Grid.Column="1" Text="4.12 GB" Foreground="#6B7280" FontSize="13" VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <Grid Margin="0,0,12,0">
                                        <TextBlock Text="68.4%" Foreground="#1A1A2E" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                                    </Grid>
                                    <ProgressBar Value="68.4" Maximum="100" Foreground="#0077FF" Style="{StaticResource DashProgressBarStyle}"/>
                                </StackPanel>

                                <TextBlock Grid.Column="3" Text="12.4 MB/s" Foreground="#1A1A2E" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="4" Text="02:45" Foreground="#6B7280" FontSize="13" VerticalAlignment="Center"/>

                                <Border Grid.Column="5" Style="{StaticResource StatusBadgeDownloading}" HorizontalAlignment="Left">
                                    <TextBlock Text="Downloading" Foreground="#0077FF" FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Row 2 -->
                        <Border Padding="16,12,16,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="1.8*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="32" Height="32" CornerRadius="6" Background="#EFF6FF" Margin="0,0,10,0">
                                        <fa:ImageAwesome Icon="FileVideoOutline" Width="14" Foreground="#0077FF" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Nature Documentary 4K.mp4" Foreground="#1A1A2E" FontSize="13" FontWeight="Medium"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="280"/>
                                </StackPanel>

                                <TextBlock Grid.Column="1" Text="2.35 GB" Foreground="#6B7280" FontSize="13" VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <Grid Margin="0,0,12,0">
                                        <TextBlock Text="23.7%" Foreground="#1A1A2E" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                                    </Grid>
                                    <ProgressBar Value="23.7" Maximum="100" Foreground="#0077FF" Style="{StaticResource DashProgressBarStyle}"/>
                                </StackPanel>

                                <TextBlock Grid.Column="3" Text="8.7 MB/s" Foreground="#1A1A2E" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="4" Text="04:18" Foreground="#6B7280" FontSize="13" VerticalAlignment="Center"/>

                                <Border Grid.Column="5" Style="{StaticResource StatusBadgeDownloading}" HorizontalAlignment="Left">
                                    <TextBlock Text="Downloading" Foreground="#0077FF" FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===================== 4. RECENT COMPLETED TABLE ===================== -->
            <Border Grid.Row="5" Background="{StaticResource DashCardBg}" BorderBrush="{StaticResource DashBorder}"
                    BorderThickness="1" CornerRadius="12" Padding="0" Margin="0,20,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Header -->
                        <RowDefinition Height="Auto"/>
                        <!-- Rows -->
                    </Grid.RowDefinitions>

                    <!-- Section Header -->
                    <Grid Grid.Row="0" Margin="20,16,20,0">
                        <TextBlock Text="Recent Completed" Style="{StaticResource DashSectionTitle}"/>
                        <TextBlock Text="View All" Style="{StaticResource DashViewAllBtn}" HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Column Headers -->
                    <Grid Grid.Row="0" Margin="20,44,20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="2.5*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="FILE NAME" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF"/>
                        <TextBlock Grid.Column="1" Text="SIZE" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF"/>
                        <TextBlock Grid.Column="2" Text="COMPLETED" FontSize="11" FontWeight="SemiBold" Foreground="#9CA3AF"/>
                    </Grid>

                    <Border Grid.Row="0" Height="1" Background="{StaticResource DashBorder}" Margin="20,60,20,0"/>

                    <!-- Completed Rows -->
                    <StackPanel Grid.Row="1">
                        <!-- Row 1 -->
                        <Border Padding="16,12,16,12" BorderBrush="{StaticResource DashBorder}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="2.5*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="32" Height="32" CornerRadius="6" Background="#F0FDF4" Margin="0,0,10,0">
                                        <fa:ImageAwesome Icon="FilePdfOutline" Width="14" Foreground="#22C55E" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="project-report-final.pdf" Foreground="#1A1A2E" FontSize="13" FontWeight="Medium"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <TextBlock Grid.Column="1" Text="12.4 MB" Foreground="#6B7280" FontSize="13" VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock Text="Completed 2h ago" Foreground="#9CA3AF" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <fa:ImageAwesome Icon="CheckCircle" Width="16" Foreground="#22C55E" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Row 2 -->
                        <Border Padding="16,12,16,12" BorderBrush="{StaticResource DashBorder}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="2.5*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="32" Height="32" CornerRadius="6" Background="#EFF6FF" Margin="0,0,10,0">
                                        <fa:ImageAwesome Icon="FileCodeOutline" Width="14" Foreground="#0077FF" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="setup-mac1-downloader.exe" Foreground="#1A1A2E" FontSize="13" FontWeight="Medium"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <TextBlock Grid.Column="1" Text="28.7 MB" Foreground="#6B7280" FontSize="13" VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock Text="Completed 5h ago" Foreground="#9CA3AF" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <fa:ImageAwesome Icon="CheckCircle" Width="16" Foreground="#22C55E" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Row 3 -->
                        <Border Padding="16,12,16,12" BorderBrush="{StaticResource DashBorder}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="2.5*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="32" Height="32" CornerRadius="6" Background="#FDF4FF" Margin="0,0,10,0">
                                        <fa:ImageAwesome Icon="FileAudioOutline" Width="14" Foreground="#A855F7" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="background-music.mp3" Foreground="#1A1A2E" FontSize="13" FontWeight="Medium"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <TextBlock Grid.Column="1" Text="7.8 MB" Foreground="#6B7280" FontSize="13" VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock Text="Completed 1d ago" Foreground="#9CA3AF" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <fa:ImageAwesome Icon="CheckCircle" Width="16" Foreground="#22C55E" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Row 4 -->
                        <Border Padding="16,12,16,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="2.5*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="32" Height="32" CornerRadius="6" Background="#EFF6FF" Margin="0,0,10,0">
                                        <fa:ImageAwesome Icon="FileVideoOutline" Width="14" Foreground="#0077FF" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="movie-trailer-1080p.mp4" Foreground="#1A1A2E" FontSize="13" FontWeight="Medium"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <TextBlock Grid.Column="1" Text="95.3 MB" Foreground="#6B7280" FontSize="13" VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock Text="Completed 2d ago" Foreground="#9CA3AF" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <fa:ImageAwesome Icon="CheckCircle" Width="16" Foreground="#22C55E" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>
