<UserControl x:Class="MAC_1.Views.DownloadingSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="900">
    <UserControl.Resources>
        <!-- Progress Bar Style -->
        <Style x:Key="DownloadProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="5"/>
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                            <Border x:Name="PART_Track" CornerRadius="3"/>
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="3">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#3B82F6" Offset="0"/>
                                        <GradientStop Color="#60A5FA" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Paused Progress Bar -->
        <Style x:Key="PausedProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="5"/>
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                            <Border x:Name="PART_Track" CornerRadius="3"/>
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="3">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#F59E0B" Offset="0"/>
                                        <GradientStop Color="#FBBF24" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Error Progress Bar -->
        <Style x:Key="ErrorProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="5"/>
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                            <Border x:Name="PART_Track" CornerRadius="3"/>
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="3">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#EF4444" Offset="0"/>
                                        <GradientStop Color="#F87171" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Border Background="White">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="28,20,28,20">
                <!-- HEADER -->
                <Grid Margin="0,0,0,18">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Downloads" FontSize="22" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                        <Border Background="#3B82F6" CornerRadius="10" Padding="8,3" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="3" FontSize="11" FontWeight="Bold" Foreground="White"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Width="32" Height="32" CornerRadius="8" Background="#F1F5F9" Margin="0,0,8,0" Cursor="Hand">
                            <fa:ImageAwesome Icon="List" Width="12" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Width="32" Height="32" CornerRadius="8" Background="#EFF6FF" Margin="0,0,8,0" Cursor="Hand">
                            <fa:ImageAwesome Icon="ThLarge" Width="12" Foreground="#3B82F6" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Width="32" Height="32" CornerRadius="8" Background="#F1F5F9" Cursor="Hand">
                            <fa:ImageAwesome Icon="EllipsisH" Width="12" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Grid>
                <!-- FILTER TABS -->
                <Border Background="#F8FAFC" CornerRadius="12" Padding="5,5" Margin="0,0,0,18">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#3B82F6" CornerRadius="8" Padding="13,6" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="All" FontSize="12" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                <Border Background="#2563EB" CornerRadius="6" Padding="5,2" Margin="8,0,0,0">
                                    <TextBlock Text="3" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <Border Background="Transparent" CornerRadius="8" Padding="13,6" Cursor="Hand" Margin="3,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Downloading" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center"/>
                                <Border Background="#E5E7EB" CornerRadius="6" Padding="5,2" Margin="8,0,0,0">
                                    <TextBlock Text="1" FontSize="10" FontWeight="Bold" Foreground="#64748B"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <Border Background="Transparent" CornerRadius="8" Padding="13,6" Cursor="Hand" Margin="3,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Paused" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center"/>
                                <Border Background="#E5E7EB" CornerRadius="6" Padding="5,2" Margin="8,0,0,0">
                                    <TextBlock Text="1" FontSize="10" FontWeight="Bold" Foreground="#64748B"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <Border Background="Transparent" CornerRadius="8" Padding="13,6" Cursor="Hand" Margin="3,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Completed" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center"/>
                                <Border Background="#E5E7EB" CornerRadius="6" Padding="5,2" Margin="8,0,0,0">
                                    <TextBlock Text="0" FontSize="10" FontWeight="Bold" Foreground="#64748B"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <Border Background="Transparent" CornerRadius="8" Padding="13,6" Cursor="Hand" Margin="3,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Failed" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center"/>
                                <Border Background="#E5E7EB" CornerRadius="6" Padding="5,2" Margin="8,0,0,0">
                                    <TextBlock Text="1" FontSize="10" FontWeight="Bold" Foreground="#64748B"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ═══════════════════════════════════════════ -->
                <!-- CARD 1 - Downloading                        -->
                <!-- ═══════════════════════════════════════════ -->
                <Border Background="#FAFBFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="14" Padding="16,14" Margin="0,0,0,10">
                    <StackPanel>
                        <!-- Row 1: Icon + Info + Actions -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- File type icon -->
                            <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10" Background="#EFF6FF">
                                <fa:ImageAwesome Icon="Windows" Width="18" Foreground="#3B82F6" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <!-- File info -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="Windows_11_Pro_23H2.iso" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="4.2 GB" FontSize="11" Foreground="#64748B"/>
                                    <TextBlock Text="  ·  " FontSize="11" Foreground="#CBD5E1"/>
                                    <TextBlock Text="3.15 GB / 4.2 GB" FontSize="11" Foreground="#64748B"/>
                                    <TextBlock Text="  ·  " FontSize="11" Foreground="#CBD5E1"/>
                                    <TextBlock Text="23 chunks" FontSize="11" Foreground="#64748B"/>
                                </StackPanel>
                            </StackPanel>
                            <!-- Action buttons -->
                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Pause/Resume toggle -->
                                <Border Width="30" Height="30" CornerRadius="7" Background="#EFF6FF" Cursor="Hand" Margin="0,0,5,0" ToolTip="Pause">
                                    <fa:ImageAwesome Icon="Pause" Width="11" Foreground="#3B82F6" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <!-- Delete -->
                                <Border Width="30" Height="30" CornerRadius="7" Background="#FEF2F2" Cursor="Hand" Margin="0,0,5,0" ToolTip="Remove">
                                    <fa:ImageAwesome Icon="Trash" Width="11" Foreground="#EF4444" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <!-- More -->
                                <Border Width="30" Height="30" CornerRadius="7" Background="#F1F5F9" Cursor="Hand" ToolTip="More options">
                                    <fa:ImageAwesome Icon="EllipsisH" Width="11" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                        <!-- Row 2: Progress -->
                        <ProgressBar Value="75" Maximum="100" Style="{StaticResource DownloadProgressBar}" Margin="0,12,0,0"/>
                        <!-- Row 3: Speed + ETA + Percent -->
                        <Grid Margin="0,7,0,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <fa:ImageAwesome Icon="ArrowDown" Width="9" Foreground="#3B82F6" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="2.5 MB/s" FontSize="11" FontWeight="SemiBold" Foreground="#3B82F6" VerticalAlignment="Center"/>
                                <TextBlock Text="  ·  6 connections" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="ETA 05:32" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="75%" FontSize="13" FontWeight="Bold" Foreground="#3B82F6" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ═══════════════════════════════════════════ -->
                <!-- CARD 2 - Paused                            -->
                <!-- ═══════════════════════════════════════════ -->
                <Border Background="#FAFBFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="14" Padding="16,14" Margin="0,0,0,10">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10" Background="#FEF3C7">
                                <fa:ImageAwesome Icon="Film" Width="18" Foreground="#D97706" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="The_Batman_2022_4K_UHD.mp4" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="8.7 GB" FontSize="11" Foreground="#64748B"/>
                                    <TextBlock Text="  ·  " FontSize="11" Foreground="#CBD5E1"/>
                                    <TextBlock Text="2.61 GB / 8.7 GB" FontSize="11" Foreground="#64748B"/>
                                    <TextBlock Text="  ·  " FontSize="11" Foreground="#CBD5E1"/>
                                    <TextBlock Text="16 chunks" FontSize="11" Foreground="#64748B"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Resume -->
                                <Border Width="30" Height="30" CornerRadius="7" Background="#F0FDF4" Cursor="Hand" Margin="0,0,5,0" ToolTip="Resume">
                                    <fa:ImageAwesome Icon="Play" Width="11" Foreground="#16A34A" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <!-- Delete -->
                                <Border Width="30" Height="30" CornerRadius="7" Background="#FEF2F2" Cursor="Hand" Margin="0,0,5,0" ToolTip="Remove">
                                    <fa:ImageAwesome Icon="Trash" Width="11" Foreground="#EF4444" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <!-- More -->
                                <Border Width="30" Height="30" CornerRadius="7" Background="#F1F5F9" Cursor="Hand" ToolTip="More options">
                                    <fa:ImageAwesome Icon="EllipsisH" Width="11" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                        <ProgressBar Value="30" Maximum="100" Style="{StaticResource PausedProgressBar}" Margin="0,12,0,0"/>
                        <Grid Margin="0,7,0,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="7" Height="7" CornerRadius="4" Background="#F59E0B" Margin="0,0,5,0"/>
                                <TextBlock Text="Paused" FontSize="11" FontWeight="SemiBold" Foreground="#F59E0B" VerticalAlignment="Center"/>
                                <TextBlock Text="  ·  4 connections" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="8 min ago" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="30%" FontSize="13" FontWeight="Bold" Foreground="#F59E0B" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ═══════════════════════════════════════════ -->
                <!-- CARD 3 - Failed / Connecting               -->
                <!-- ═══════════════════════════════════════════ -->
                <Border Background="#FAFBFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="14" Padding="16,14">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10" Background="#FEF2F2">
                                <fa:ImageAwesome Icon="Archive" Width="18" Foreground="#EF4444" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="Adobe_Photoshop_2024.zip" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="2.1 GB" FontSize="11" Foreground="#64748B"/>
                                    <TextBlock Text="  ·  " FontSize="11" Foreground="#CBD5E1"/>
                                    <TextBlock Text="0 B / 2.1 GB" FontSize="11" Foreground="#64748B"/>
                                    <TextBlock Text="  ·  " FontSize="11" Foreground="#CBD5E1"/>
                                    <TextBlock Text="32 chunks" FontSize="11" Foreground="#64748B"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Retry -->
                                <Border Width="30" Height="30" CornerRadius="7" Background="#EFF6FF" Cursor="Hand" Margin="0,0,5,0" ToolTip="Retry">
                                    <fa:ImageAwesome Icon="RotateRight" Width="11" Foreground="#3B82F6" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <!-- Delete -->
                                <Border Width="30" Height="30" CornerRadius="7" Background="#FEF2F2" Cursor="Hand" Margin="0,0,5,0" ToolTip="Remove">
                                    <fa:ImageAwesome Icon="Trash" Width="11" Foreground="#EF4444" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <!-- More -->
                                <Border Width="30" Height="30" CornerRadius="7" Background="#F1F5F9" Cursor="Hand" ToolTip="More options">
                                    <fa:ImageAwesome Icon="EllipsisH" Width="11" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                        <ProgressBar Value="0" Maximum="100" Style="{StaticResource ErrorProgressBar}" Margin="0,12,0,0"/>
                        <Grid Margin="0,7,0,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="7" Height="7" CornerRadius="4" Background="#EF4444" Margin="0,0,5,0"/>
                                <TextBlock Text="Connection failed" FontSize="11" FontWeight="SemiBold" Foreground="#EF4444" VerticalAlignment="Center"/>
                                <TextBlock Text="  ·  Server timeout" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="2 min ago" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="0%" FontSize="13" FontWeight="Bold" Foreground="#EF4444" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
