<UserControl x:Class="MAC_1.Views.QueueSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="900">
    <UserControl.Resources>
        <Style x:Key="SlimProgress" TargetType="ProgressBar">
            <Setter Property="Height" Value="4"/>
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="2"/>
                            <Border x:Name="PART_Track" CornerRadius="2"/>
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="2">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#3B82F6" Offset="0"/>
                                        <GradientStop Color="#60A5FA" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Border Background="White">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="28,20,28,24">

                <!-- HEADER -->
                <Grid Margin="0,0,0,20">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Queue" FontSize="22" FontWeight="Bold" Foreground="#0F172A"/>
                        <TextBlock Text="Manage and organize your queued downloads" FontSize="12" Foreground="#94A3B8" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Background="#3B82F6" CornerRadius="10" Padding="14,8" Cursor="Hand" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <fa:ImageAwesome Icon="Plus" Width="12" Foreground="White" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock Text="Add Download" FontSize="12" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#F0FDF4" CornerRadius="10" Padding="14,8" Cursor="Hand" Margin="0,0,8,0" BorderBrush="#BBF7D0" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <fa:ImageAwesome Icon="Play" Width="11" Foreground="#16A34A" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock Text="Start Queue" FontSize="12" FontWeight="SemiBold" Foreground="#16A34A" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#FFFBEB" CornerRadius="10" Padding="14,8" Cursor="Hand" BorderBrush="#FDE68A" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <fa:ImageAwesome Icon="Pause" Width="11" Foreground="#D97706" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock Text="Pause Queue" FontSize="12" FontWeight="SemiBold" Foreground="#D97706" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- OVERVIEW STATS -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="14" Padding="18,14">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="36" Height="36" CornerRadius="9" Background="#EFF6FF" Margin="0,0,10,0">
                                <fa:ImageAwesome Icon="ListOl" Width="16" Foreground="#3B82F6" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Total Items" FontSize="11" Foreground="#94A3B8"/>
                                <TextBlock x:Name="StatTotal" Text="5" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="14" Padding="18,14">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="36" Height="36" CornerRadius="9" Background="#FFFBEB" Margin="0,0,10,0">
                                <fa:ImageAwesome Icon="History" Width="16" Foreground="#D97706" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Waiting" FontSize="11" Foreground="#94A3B8"/>
                                <TextBlock x:Name="StatWaiting" Text="3" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="14" Padding="18,14">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="36" Height="36" CornerRadius="9" Background="#F0FDF4" Margin="0,0,10,0">
                                <fa:ImageAwesome Icon="Download" Width="16" Foreground="#16A34A" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Active" FontSize="11" Foreground="#94A3B8"/>
                                <TextBlock x:Name="StatActive" Text="2" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="6" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="14" Padding="18,14">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="36" Height="36" CornerRadius="9" Background="#FEF2F2" Margin="0,0,10,0">
                                <fa:ImageAwesome Icon="History" Width="16" Foreground="#EF4444" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="ETA" FontSize="11" Foreground="#94A3B8"/>
                                <TextBlock Text="~18 min" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- BULK ACTION BAR (hidden by default) -->
                <Border x:Name="BulkActionBar" Background="#EFF6FF" CornerRadius="12" Padding="14,10" Margin="0,0,0,14" BorderBrush="#BFDBFE" BorderThickness="1" Visibility="Collapsed">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="22" Height="22" CornerRadius="5" Background="#3B82F6" Cursor="Hand" Margin="0,0,10,0">
                                <fa:ImageAwesome Icon="Check" Width="10" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="SelectedCountText" Text="0 selected" FontSize="12" FontWeight="SemiBold" Foreground="#1E40AF" VerticalAlignment="Center" Margin="0,0,18,0"/>
                            <Border Background="White" CornerRadius="7" Padding="10,5" Cursor="Hand" Margin="0,0,6,0" BorderBrush="#BFDBFE" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <fa:ImageAwesome Icon="Play" Width="10" Foreground="#16A34A" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="Start" FontSize="11" FontWeight="SemiBold" Foreground="#374151" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="White" CornerRadius="7" Padding="10,5" Cursor="Hand" Margin="0,0,6,0" BorderBrush="#BFDBFE" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <fa:ImageAwesome Icon="Pause" Width="10" Foreground="#D97706" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="Pause" FontSize="11" FontWeight="SemiBold" Foreground="#374151" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="White" CornerRadius="7" Padding="10,5" Cursor="Hand" Margin="0,0,6,0" BorderBrush="#FECACA" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <fa:ImageAwesome Icon="Trash" Width="10" Foreground="#EF4444" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="Delete" FontSize="11" FontWeight="SemiBold" Foreground="#EF4444" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Width="1" Height="18" Background="#BFDBFE" Margin="8,0"/>
                            <Border Background="White" CornerRadius="7" Padding="10,5" Cursor="Hand" Margin="6,0,6,0" BorderBrush="#BFDBFE" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <fa:ImageAwesome Icon="ArrowUp" Width="10" Foreground="#374151" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="Top" FontSize="11" FontWeight="SemiBold" Foreground="#374151" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="White" CornerRadius="7" Padding="10,5" Cursor="Hand" Margin="0,0,6,0" BorderBrush="#BFDBFE" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <fa:ImageAwesome Icon="ArrowDown" Width="10" Foreground="#374151" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="Bottom" FontSize="11" FontWeight="SemiBold" Foreground="#374151" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Width="1" Height="18" Background="#BFDBFE" Margin="8,0"/>
                            <Border Background="White" CornerRadius="7" Padding="10,5" Cursor="Hand" Margin="6,0,0,0" BorderBrush="#BFDBFE" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <fa:ImageAwesome Icon="Flag" Width="10" Foreground="#374151" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="Priority" FontSize="11" FontWeight="SemiBold" Foreground="#374151" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonDown="BulkBarClose_Click">
                            <fa:ImageAwesome Icon="Times" Width="12" Foreground="#94A3B8" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- QUEUE ITEM 1 - Active -->
                <Border Background="#FAFBFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="14" Padding="16,14" Margin="0,0,0,10">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <fa:ImageAwesome Grid.Column="0" Icon="Bars" Width="12" Foreground="#CBD5E1" VerticalAlignment="Center" Cursor="Hand"/>
                            <!-- Checkbox 1 (checked) -->
                            <Border x:Name="Cb1" Grid.Column="1" Width="18" Height="18" CornerRadius="4" Background="#3B82F6" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonDown="Cb_Click" Tag="1">
                                <fa:ImageAwesome x:Name="CbIcon1" Icon="Check" Width="9" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="2" Width="40" Height="40" CornerRadius="10" Background="#EFF6FF">
                                <fa:ImageAwesome Icon="Windows" Width="17" Foreground="#3B82F6" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Windows_11_Pro_23H2.iso" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A" TextTrimming="CharacterEllipsis"/>
                                    <Border Background="#3B82F6" CornerRadius="5" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="#1" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                    <TextBlock Text="microsoft.com" FontSize="11" Foreground="#94A3B8"/>
                                    <TextBlock Text="  ·  " FontSize="11" Foreground="#CBD5E1"/>
                                    <TextBlock Text="4.2 GB" FontSize="11" Foreground="#94A3B8"/>
                                    <TextBlock Text="  ·  " FontSize="11" Foreground="#CBD5E1"/>
                                    <TextBlock Text="ISO Image" FontSize="11" Foreground="#94A3B8"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="5" VerticalAlignment="Center" Margin="12,0,0,0">
                                <Border Background="#EFF6FF" CornerRadius="6" Padding="8,3" HorizontalAlignment="Right" Margin="0,0,0,6">
                                    <TextBlock Text="High" FontSize="10" FontWeight="SemiBold" Foreground="#3B82F6"/>
                                </Border>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Border Width="6" Height="6" CornerRadius="3" Background="#22C55E" Margin="0,0,5,0"/>
                                    <TextBlock Text="Downloading" FontSize="11" FontWeight="SemiBold" Foreground="#22C55E"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        <ProgressBar Value="75" Maximum="100" Style="{StaticResource SlimProgress}" Margin="0,12,0,0"/>
                        <Grid Margin="0,7,0,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <fa:ImageAwesome Icon="ArrowDown" Width="9" Foreground="#3B82F6" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="2.5 MB/s" FontSize="11" FontWeight="SemiBold" Foreground="#3B82F6" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="3.15 GB / 4.2 GB  ·  ETA 05:32" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="75%" FontSize="12" FontWeight="Bold" Foreground="#3B82F6" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Border Width="28" Height="28" CornerRadius="7" Background="#FEF2F2" Cursor="Hand" Margin="0,0,6,0" ToolTip="Pause">
                                <fa:ImageAwesome Icon="Pause" Width="10" Foreground="#EF4444" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Width="28" Height="28" CornerRadius="7" Background="#FEF2F2" Cursor="Hand" Margin="0,0,6,0" ToolTip="Remove">
                                <fa:ImageAwesome Icon="Trash" Width="10" Foreground="#EF4444" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Width="28" Height="28" CornerRadius="7" Background="#F1F5F9" Cursor="Hand" Margin="0,0,6,0" ToolTip="Move Up">
                                <fa:ImageAwesome Icon="ArrowUp" Width="10" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Width="28" Height="28" CornerRadius="7" Background="#F1F5F9" Cursor="Hand" Margin="0,0,6,0" ToolTip="Move Down">
                                <fa:ImageAwesome Icon="ArrowDown" Width="10" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Width="28" Height="28" CornerRadius="7" Background="#F1F5F9" Cursor="Hand" ToolTip="More options">
                                <fa:ImageAwesome Icon="EllipsisH" Width="10" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- QUEUE ITEM 2 - Active -->
                <Border Background="#FAFBFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="14" Padding="16,14" Margin="0,0,0,10">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <fa:ImageAwesome Grid.Column="0" Icon="Bars" Width="12" Foreground="#CBD5E1" VerticalAlignment="Center" Cursor="Hand"/>
                            <!-- Checkbox 2 (checked) -->
                            <Border x:Name="Cb2" Grid.Column="1" Width="18" Height="18" CornerRadius="4" Background="#3B82F6" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonDown="Cb_Click" Tag="2">
                                <fa:ImageAwesome x:Name="CbIcon2" Icon="Check" Width="9" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="2" Width="40" Height="40" CornerRadius="10" Background="#FEF3C7">
                                <fa:ImageAwesome Icon="Film" Width="17" Foreground="#D97706" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Interstellar_2014_1080p.mkv" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A" TextTrimming="CharacterEllipsis"/>
                                    <Border Background="#22C55E" CornerRadius="5" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="#2" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                    <TextBlock Text="bluray.com" FontSize="11" Foreground="#94A3B8"/>
                                    <TextBlock Text="  ·  " FontSize="11" Foreground="#CBD5E1"/>
                                    <TextBlock Text="8.7 GB" FontSize="11" Foreground="#94A3B8"/>
                                    <TextBlock Text="  ·  " FontSize="11" Foreground="#CBD5E1"/>
                                    <TextBlock Text="Video" FontSize="11" Foreground="#94A3B8"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="5" VerticalAlignment="Center" Margin="12,0,0,0">
                                <Border Background="#FFFBEB" CornerRadius="6" Padding="8,3" HorizontalAlignment="Right" Margin="0,0,0,6">
                                    <TextBlock Text="Normal" FontSize="10" FontWeight="SemiBold" Foreground="#D97706"/>
                                </Border>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Border Width="6" Height="6" CornerRadius="3" Background="#22C55E" Margin="0,0,5,0"/>
                                    <TextBlock Text="Downloading" FontSize="11" FontWeight="SemiBold" Foreground="#22C55E"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        <ProgressBar Value="42" Maximum="100" Style="{StaticResource SlimProgress}" Margin="0,12,0,0"/>
                        <Grid Margin="0,7,0,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <fa:ImageAwesome Icon="ArrowDown" Width="9" Foreground="#3B82F6" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="1.8 MB/s" FontSize="11" FontWeight="SemiBold" Foreground="#3B82F6" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="3.65 GB / 8.7 GB  ·  ETA 12:15" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="42%" FontSize="12" FontWeight="Bold" Foreground="#3B82F6" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Border Width="28" Height="28" CornerRadius="7" Background="#FEF2F2" Cursor="Hand" Margin="0,0,6,0" ToolTip="Pause">
                                <fa:ImageAwesome Icon="Pause" Width="10" Foreground="#EF4444" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Width="28" Height="28" CornerRadius="7" Background="#FEF2F2" Cursor="Hand" Margin="0,0,6,0" ToolTip="Remove">
                                <fa:ImageAwesome Icon="Trash" Width="10" Foreground="#EF4444" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Width="28" Height="28" CornerRadius="7" Background="#F1F5F9" Cursor="Hand" Margin="0,0,6,0" ToolTip="Move Up">
                                <fa:ImageAwesome Icon="ArrowUp" Width="10" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Width="28" Height="28" CornerRadius="7" Background="#F1F5F9" Cursor="Hand" Margin="0,0,6,0" ToolTip="Move Down">
                                <fa:ImageAwesome Icon="ArrowDown" Width="10" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Width="28" Height="28" CornerRadius="7" Background="#F1F5F9" Cursor="Hand" ToolTip="More options">
                                <fa:ImageAwesome Icon="EllipsisH" Width="10" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- QUEUE ITEM 3 - Waiting -->
                <Border Background="#FAFBFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="14" Padding="16,14" Margin="0,0,0,10">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <fa:ImageAwesome Grid.Column="0" Icon="Bars" Width="12" Foreground="#CBD5E1" VerticalAlignment="Center" Cursor="Hand"/>
                            <!-- Checkbox 3 (unchecked) -->
                            <Border x:Name="Cb3" Grid.Column="1" Width="18" Height="18" CornerRadius="4" Background="White" BorderBrush="#D1D5DB" BorderThickness="1.5" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonDown="Cb_Click" Tag="3">
                                <fa:ImageAwesome x:Name="CbIcon3" Icon="Check" Width="0" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="2" Width="40" Height="40" CornerRadius="10" Background="#F0FDF4">
                                <fa:ImageAwesome Icon="Archive" Width="17" Foreground="#16A34A" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Adobe_Photoshop_2024.zip" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A" TextTrimming="CharacterEllipsis"/>
                                    <Border Background="#F1F5F9" CornerRadius="5" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="#3" FontSize="9" FontWeight="Bold" Foreground="#64748B"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                    <TextBlock Text="adobe.com" FontSize="11" Foreground="#94A3B8"/>
                                    <TextBlock Text="  ·  " FontSize="11" Foreground="#CBD5E1"/>
                                    <TextBlock Text="2.1 GB" FontSize="11" Foreground="#94A3B8"/>
                                    <TextBlock Text="  ·  " FontSize="11" Foreground="#CBD5E1"/>
                                    <TextBlock Text="Archive" FontSize="11" Foreground="#94A3B8"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="5" VerticalAlignment="Center" Margin="12,0,0,0">
                                <Border Background="#F1F5F9" CornerRadius="6" Padding="8,3" HorizontalAlignment="Right" Margin="0,0,0,6">
                                    <TextBlock Text="Low" FontSize="10" FontWeight="SemiBold" Foreground="#64748B"/>
                                </Border>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Border Width="6" Height="6" CornerRadius="3" Background="#F59E0B" Margin="0,0,5,0"/>
                                    <TextBlock Text="Waiting" FontSize="11" FontWeight="SemiBold" Foreground="#F59E0B"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Border Width="28" Height="28" CornerRadius="7" Background="#F0FDF4" Cursor="Hand" Margin="0,0,6,0" ToolTip="Start">
                                <fa:ImageAwesome Icon="Play" Width="10" Foreground="#16A34A" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Width="28" Height="28" CornerRadius="7" Background="#FEF2F2" Cursor="Hand" Margin="0,0,6,0" ToolTip="Remove">
