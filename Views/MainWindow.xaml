<Window x:Class="MAC_1.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        Title="MAC-1 Downloader" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen" Foreground="White" FontFamily="Roboto">

    <!-- Clean White Background -->
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F8F9FA" Offset="0"/>
            <GradientStop Color="#FFFFFF" Offset="0.5"/>
            <GradientStop Color="#F0F2F5" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="65"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>

        <!-- 1. SIDE NAVBAR -->
        <Border x:Name="SidebarBorder" Grid.RowSpan="3" Width="220" Tag="Expanded" Background="#F0F2F5" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>

                <!-- LOGO AREA with Collapse Icon Overlay -->
                <Grid Grid.Row="0" Margin="18,10,10,0"
                      MouseEnter="LogoArea_MouseEnter" MouseLeave="LogoArea_MouseLeave">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo Icon -->
                    <Border x:Name="LogoIconBorder" Width="42" Height="42" CornerRadius="10" Background="#0077FF" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <fa:ImageAwesome Icon="CloudDownload" Width="22" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Collapse Icon (Overlay on Logo) -->
                    <Border x:Name="CollapseOverlay" Grid.Column="0" Width="42" Height="42" CornerRadius="10"
                            Background="#0055CC" VerticalAlignment="Center" HorizontalAlignment="Left"
                            Cursor="Hand" Opacity="0" MouseLeftButtonDown="CollapseBtn_Click">
                        <fa:ImageAwesome Icon="Bars" Width="16" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Logo Text -->
                    <StackPanel x:Name="LogoTextPanel" Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock Text="MAC-1" FontSize="18" FontWeight="Black" Foreground="#1A1A2E"/>
                        <TextBlock Text="Download Manager" FontSize="9" Foreground="#888" Margin="0,1,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- SEPARATOR LINE -->
                <Border Grid.Row="1" Height="1" Background="#E0E0E0" VerticalAlignment="Top" Margin="16,0"/>

                <Button Grid.Row="1" Style="{StaticResource SidebarButtonStyle}" Content="Dashboard">
                    <Button.Tag>
                        <fa:ImageAwesome Icon="Dashboard" Width="20" Foreground="#0077FF"/>
                    </Button.Tag>
                </Button>
                <hc:Badge Grid.Row="2" Value="3" BadgeMargin="0,15,15,0">
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="Downloading">
                        <Button.Tag>
                            <fa:ImageAwesome Icon="Download" Width="20" Foreground="#0077FF"/>
                        </Button.Tag>
                    </Button>
                </hc:Badge>
                <Button Grid.Row="3" Style="{StaticResource SidebarButtonStyle}" Content="Queue">
                    <Button.Tag>
                        <fa:ImageAwesome Icon="ListOl" Width="20" Foreground="#0077FF"/>
                    </Button.Tag>
                </Button>
                <Button Grid.Row="4" Style="{StaticResource SidebarButtonStyle}" Content="Torrent">
                    <Button.Tag>
                        <fa:ImageAwesome Icon="Magnet" Width="20" Foreground="#0077FF"/>
                    </Button.Tag>
                </Button>
                <Button Grid.Row="5" Style="{StaticResource SidebarButtonStyle}" Content="Finished">
                    <Button.Tag>
                        <fa:ImageAwesome Icon="CheckCircle" Width="20" Foreground="#0077FF"/>
                    </Button.Tag>
                </Button>
                <Button Grid.Row="6" Style="{StaticResource SidebarButtonStyle}" Content="History">
                    <Button.Tag>
                        <fa:ImageAwesome Icon="History" Width="20" Foreground="#0077FF"/>
                    </Button.Tag>
                </Button>
                <Button Grid.Row="8" Style="{StaticResource SidebarButtonStyle}" Content="Settings" ToolTip="Rotate">
                    <Button.Tag>
                        <fa:ImageAwesome Icon="Gear" Width="20" Foreground="#0077FF"/>
                    </Button.Tag>
                </Button>
            </Grid>
        </Border>

        <!-- 2. TOP NAVBAR (White Theme) -->
        <Border Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Background="#FFFFFF" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Button Content="+ ADD NEW URL" Style="{StaticResource PulseAddButtonStyle}" Cursor="Hand"/>
                    <Rectangle Width="40"/>
                    <Button Content="RESUME ALL" Style="{StaticResource TopNavActionButtonStyle}"/>
                    <Button Content="PAUSE ALL" Style="{StaticResource TopNavActionButtonStyle}"/>
                    <Button Content="SCHEDULER" Style="{StaticResource TopNavActionButtonStyle}"/>
                </StackPanel>
                <TextBox Style="{StaticResource ModernSearchBox}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- 3. MAIN DOWNLOAD AREA (White Background) -->
        <Border Grid.Row="1" Grid.Column="1" BorderBrush="#E8E8E8" BorderThickness="0,0,1,0" Background="White"/>

        <!-- 4. RIGHT PANEL (Two Sections) -->
        <Grid Grid.Row="1" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <!-- Top Box (Meters & Stats) -->
                <RowDefinition Height="*"/>
                <!-- Bottom Box (Free/Empty) -->
            </Grid.RowDefinitions>

            <!-- TOP BOX: METERS & STATS (White Theme) -->
            <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E8E8E8" BorderThickness="0,0,1,1">
                <Border.Resources>
                    <Style x:Key="LocalMeterTitle" TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#888"/>
                        <Setter Property="FontSize" Value="9"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="HorizontalAlignment" Value="Center"/>
                        <Setter Property="Margin" Value="0,0,0,3"/>
                    </Style>
                    <Style x:Key="LocalCircularStyle" TargetType="ProgressBar">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ProgressBar">
                                    <Grid>
                                        <hc:Arc StrokeThickness="5" Stroke="#E8E8E8" StartAngle="0" EndAngle="360"/>
                                        <hc:Arc StrokeThickness="5" Stroke="{TemplateBinding Foreground}" StartAngle="0" EndAngle="280"/>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Border.Resources>

                <Grid Margin="10,5">
                    <!-- Reduced top/bottom margin -->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- M1/M2 -->
                        <RowDefinition Height="Auto"/>
                        <!-- Line -->
                        <RowDefinition Height="*"/>
                        <!-- M3 & Stats -->
                    </Grid.RowDefinitions>

                    <!-- Row 1: Download & Upload (Standard size) -->
                    <UniformGrid Grid.Row="0" Columns="2" VerticalAlignment="Center" Margin="0,5">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="DOWNLOAD" Style="{StaticResource LocalMeterTitle}"/>
                            <Grid Width="65" Height="65">
                                <ProgressBar Value="75" Foreground="#0077FF" Style="{StaticResource LocalCircularStyle}"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="45.2" FontSize="11" FontWeight="Black" HorizontalAlignment="Center" Foreground="#1A1A2E"/>
                                    <TextBlock Text="Mbps" Foreground="#888" FontSize="7" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="UPLOAD" Style="{StaticResource LocalMeterTitle}"/>
                            <Grid Width="65" Height="65">
                                <ProgressBar Value="30" Foreground="#FF3366" Style="{StaticResource LocalCircularStyle}"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="12.8" FontSize="11" FontWeight="Black" HorizontalAlignment="Center" Foreground="#1A1A2E"/>
                                    <TextBlock Text="Mbps" Foreground="#888" FontSize="7" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </UniformGrid>

                    <Rectangle Grid.Row="1" Height="1" Fill="#E8E8E8" Margin="10,8"/>

                    <!-- Row 2: Selected File Speed & Stats (Compact) -->
                    <StackPanel Grid.Row="2" VerticalAlignment="Top">
                        <TextBlock Text="SELECTED FILE SPEED" Style="{StaticResource LocalMeterTitle}" Foreground="#0077FF"/>
                        <Grid Width="100" Height="100" HorizontalAlignment="Center">
                            <ProgressBar Value="60" Foreground="#00BCD4" Style="{StaticResource LocalCircularStyle}"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="32.5" Foreground="#00BCD4" FontSize="18" FontWeight="Black" HorizontalAlignment="Center"/>
                                <TextBlock Text="Mbps" Foreground="#888" FontSize="9" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- THREE STATS -->
                        <Grid Margin="5,12,5,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="TOTAL SIZE" Foreground="#AAA" FontSize="8" FontWeight="Bold"/>
                                <TextBlock Text="1.4 GB" Foreground="#1A1A2E" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="OVERHEAD" Foreground="#AAA" FontSize="8" FontWeight="Bold"/>
                                <TextBlock Text="1.2 MB" Foreground="#1A1A2E" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="REMAINING" Foreground="#AAA" FontSize="8" FontWeight="Bold"/>
                                <TextBlock Text="05:42 MIN" Foreground="#0077FF" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
            <!-- 5. BOTTOM BOX: PERFORMANCE & CHUNKS MONITOR (White Theme) -->
            <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                <Border.Resources>
                    <!-- Local Styles for System Gauges -->
                    <Style x:Key="SmallGaugeStyle" TargetType="ProgressBar">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ProgressBar">
                                    <Grid>
                                        <hc:Arc StrokeThickness="4" Stroke="#E8E8E8" StartAngle="0" EndAngle="360"/>
                                        <hc:Arc StrokeThickness="4" Stroke="{TemplateBinding Foreground}" StartAngle="0" EndAngle="240"/>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <!-- Style for Chunk Bars -->
                    <Style x:Key="ChunkBarStyle" TargetType="ProgressBar">
                        <Setter Property="Height" Value="4"/>
                        <Setter Property="Background" Value="#E8E8E8"/>
                        <Setter Property="Foreground" Value="#0077FF"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Margin" Value="2"/>
                    </Style>
                </Border.Resources>

                <Grid Margin="15,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="15"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="PERFORMANCE MONITOR" Foreground="#888" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <!-- CPU & RAM GAUGES -->
                    <UniformGrid Grid.Row="1" Columns="2">
                        <StackPanel HorizontalAlignment="Center">
                            <Grid Width="50" Height="50">
                                <ProgressBar Value="45" Foreground="#FF9800" Style="{StaticResource SmallGaugeStyle}"/>
                                <TextBlock Text="45%" Foreground="#1A1A2E" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="CPU USAGE" Foreground="#AAA" FontSize="8" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>

                        <StackPanel HorizontalAlignment="Center">
                            <Grid Width="50" Height="50">
                                <ProgressBar Value="62" Foreground="#2196F3" Style="{StaticResource SmallGaugeStyle}"/>
                                <TextBlock Text="62%" Foreground="#1A1A2E" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="RAM USAGE" Foreground="#AAA" FontSize="8" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </UniformGrid>

                    <TextBlock Grid.Row="3" Text="ACTIVE DOWNLOAD CHUNKS (32 THREADS)" Foreground="#AAA" FontSize="8" FontWeight="Bold" Margin="5,0,0,5"/>

                    <!-- 32 CHUNKS MATRIX (4 columns x 8 rows) -->
                    <UniformGrid Grid.Row="4" Columns="4" Rows="8" Margin="0,5">
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="80"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="40"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="90"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="10"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="60"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="30"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="50"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="70"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="20"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="85"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="45"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="95"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="15"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="55"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="75"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="35"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="80"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="40"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="90"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="10"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="60"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="30"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="50"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="70"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="20"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="85"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="45"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="95"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="15"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="55"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="75"/>
                        <ProgressBar Style="{StaticResource ChunkBarStyle}" Value="35"/>
                    </UniformGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- 6. BOTTOM NAVBAR -->
        <!-- 6. BOTTOM NAVBAR (White Theme) -->
        <Border Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="2"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Global Progress Bar -->
                <ProgressBar Grid.Row="0" Value="65" Height="2" Background="Transparent" Foreground="#0077FF" BorderThickness="0"/>

                <!-- Content Area -->
                <Grid Grid.Row="1" Margin="15,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Ellipse Width="6" Height="6" Style="{StaticResource BlinkingDotStyle}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="STATUS:" Style="{StaticResource BottomNavTextStyle}" Foreground="#888"/>
                        <TextBlock Text="DOWNLOADING (2 FILES ACTIVE)" Style="{StaticResource BottomNavValueStyle}" Foreground="#00AA00"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <fa:ImageAwesome Icon="Database" Width="10" Foreground="#AAA" Margin="0,0,5,0"/>
                        <TextBlock Text="DISK:" Style="{StaticResource BottomNavTextStyle}" Foreground="#888"/>
                        <TextBlock Text="42 MB/s" Style="{StaticResource BottomNavValueStyle}" Foreground="#333"/>

                        <fa:ImageAwesome Icon="Signal" Width="10" Foreground="#AAA" Margin="0,0,5,0"/>
                        <TextBlock Text="PING:" Style="{StaticResource BottomNavTextStyle}" Foreground="#888"/>
                        <TextBlock Text="45 ms" Style="{StaticResource BottomNavValueStyle}" Foreground="#333"/>

                        <fa:ImageAwesome Icon="Link" Width="10" Foreground="#AAA" Margin="0,0,5,0"/>
                        <TextBlock Text="CONNS:" Style="{StaticResource BottomNavTextStyle}" Foreground="#888"/>
                        <TextBlock Text="32/32" Style="{StaticResource BottomNavValueStyle}" Foreground="#333"/>

                        <Button Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Open Downloads Folder">
                            <fa:ImageAwesome Icon="FolderOpen" Width="14" Foreground="#0077FF" Opacity="0.8"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>