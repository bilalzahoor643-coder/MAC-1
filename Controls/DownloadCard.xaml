<UserControl x:Class="MAC_1.Views.DownloadCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/">

    <UserControl.Resources>
        <!-- Converter for Hide/Show Stats -->
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Border Style="{StaticResource ModernCardStyle}" Padding="15" Cursor="Hand">
        <!-- Pure card clickable for Expand/Collapse -->
        <Border.InputBindings>
            <MouseBinding MouseAction="LeftClick" Command="{Binding ToggleExpandCommand}"/>
        </Border.InputBindings>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Top: Info & All Buttons -->
                <RowDefinition Height="Auto"/>
                <!-- Middle: Progress Bar -->
                <RowDefinition Height="Auto"/>
                <!-- Bottom: Expandable Stats -->
            </Grid.RowDefinitions>

            <!-- ================= 1. TOP SECTION ================= -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Icon -->
                    <ColumnDefinition Width="*"/>
                    <!-- File Info -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Buttons Panel -->
                </Grid.ColumnDefinitions>

                <!-- Left: File Icon -->
                <Border Grid.Column="0" Width="60" Height="60" Background="#F0F2F5" CornerRadius="8" BorderBrush="#E8E8E8" BorderThickness="1" Margin="0,0,15,0">
                    <fa:ImageAwesome Icon="PlayCircle" Width="30" Foreground="#0077FF"/>
                </Border>

                <!-- Middle: Real Data Bindings -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,10,0">
                    <TextBlock Text="{Binding Task.Filename}" Foreground="#1A1A2E" FontSize="18" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Task.Url}" Foreground="#888" FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Task.SavePath}" Foreground="#AAA" FontSize="10" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- Right: Dynamic Action Buttons & Menu -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,5,0,0">

                    <!-- DYNAMIC BUTTONS LOOP -->
                    <ItemsControl ItemsSource="{Binding FrontButtons}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Binding Background, Icon, Command and Parameter -->
                                <Button Style="{StaticResource CircleBtnStyle}" 
                        Background="{Binding HexColor}"
                        Command="{Binding DataContext.ActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding ActionName}"
                        ToolTip="{Binding ToolTip}">
                                    <fa:ImageAwesome Icon="{Binding Icon}" Width="10" Foreground="White"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    
                    <!-- 3-DOT MENU BUTTON -->
                    <!-- 3-DOT MENU BUTTON SECTION -->
                    <Grid Grid.Column="2" Margin="5,0,0,0">
                        <!-- Asli Button -->
                        <Button x:Name="DotsButton" 
            Width="30" Height="30" 
            Background="Transparent" 
            BorderThickness="0" 
            Cursor="Hand"
            Click="DotsButton_Click">
                            <!-- Code-behind mein chota sa trigger chahiye hoga -->
                            <fa:ImageAwesome Icon="EllipsisV" Width="6" Foreground="#AAA"/>
                        </Button>

                        <!-- THE POPUP (Windows Desktop Style Menu) -->
                        <Popup x:Name="MenuPopup" 
           PlacementTarget="{Binding ElementName=DotsButton}" 
           Placement="Bottom" 
           StaysOpen="False" 
           AllowsTransparency="True" 
           PopupAnimation="Fade">

                            <Border Background="#FFFFFF" 
                BorderBrush="#E0E0E0" 
                BorderThickness="1" 
                CornerRadius="10" 
                Padding="5" 
                Width="180">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.2" Color="#000000"/>
                                </Border.Effect>

                                <!-- Menu Items Loop -->
                                <ItemsControl ItemsSource="{Binding MenuItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource ModernMenuItemButtonStyle}"
                                Command="{Binding DataContext.ActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding ActionName}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="30"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <fa:ImageAwesome Grid.Column="0" Icon="{Binding Icon}" Width="12" Foreground="#888" HorizontalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Text}" Foreground="#333" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </Popup>
                    </Grid>
                </StackPanel>
            </Grid>

            
            <!-- ================= 2. PROGRESS SECTION ================= -->
            <StackPanel Grid.Row="1" Margin="0,20,0,15">
                <Grid Margin="0,0,0,8">
                    <TextBlock Text="{Binding Task.State}" Foreground="#1A1A2E" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding ProgressPercent}" Foreground="#0077FF" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"/>
                </Grid>
                <!-- Green Progress Bar -->
                <ProgressBar Value="{Binding Task.Progress}" 
             Maximum="100" 
             Minimum="0"
             Style="{StaticResource RoundedProgressBarStyle}"/>
            </StackPanel>

            <!-- ================= 3. BOTTOM STATS (Expandable) ================= -->
            <Border Grid.Row="2" 
                    BorderBrush="#E8E8E8" 
                    BorderThickness="0,1,0,0" 
                    Padding="0,12,0,0"
                    Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <!-- Divider 1 -->
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <!-- Divider 2 -->
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Time Left -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                        <fa:ImageAwesome Icon="ClockOutline" Width="12" Foreground="#AAA" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Task.TimeRemaining}" Foreground="#888" FontSize="11"/>
                    </StackPanel>

                    <!-- Divider -->
                    <Border Grid.Column="1" Width="1" Height="15" Background="#E8E8E8" Margin="10,0"/>

                    <!-- Speed -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                        <fa:ImageAwesome Icon="Wifi" Width="14" Foreground="#AAA" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Task.Speed}" Foreground="#1A1A2E" FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Divider -->
                    <Border Grid.Column="3" Width="1" Height="15" Background="#E8E8E8" Margin="10,0"/>

                    <!-- Size Info -->
                    <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Center">
                        <fa:ImageAwesome Icon="Folder" Width="14" Foreground="#AAA" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding SizeDisplay}" Foreground="#888" FontSize="11" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>