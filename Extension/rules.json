[
  {
    "id": 1,
    "priority": 1,
    "action": {
      "type": "redirect",
      "redirect": {
        "regexSubstitution": "chrome-extension://{extensionId}/intercept.html?redirect={redirectUrl}"
      }
    },
    "condition": {
      "regexFilter": ".*\\.(zip|rar|7z|tar|gz|bz2|xz|exe|msi|dmg|apk|pdf|doc|docx|xls|xlsx|ppt|pptx|mp4|mkv|avi|mov|wmv|flv|webm|m4v|mp3|flac|wav|aac|ogg|wma|iso|bin|cue|img)(\\?.*)?$",
      "resourceTypes": ["main_frame", "sub_frame", "xmlhttprequest"]
    }
  }
]
